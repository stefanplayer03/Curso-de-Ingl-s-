# Firebase — copie para .env.local e preencha com os dados do seu projeto
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Camada de IA (abstraída — trocar de provedor não deve exigir reescrever o app)
# Ex: "gemini" | "vertex" | "mock"
VITE_AI_PROVIDER=mock
VITE_AI_API_KEY=
