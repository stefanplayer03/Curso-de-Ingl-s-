# Firebase — copie para .env.local e preencha com os dados do seu projeto.
# Estas são "VITE_" de propósito: vão para o bundle do navegador (não são segredo).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Camada de IA — qual provider o app deve usar.
# "mock" (padrão, sem custo) | "gemini" | "groq" (real, escolha um) | "vertex" (ainda não implementado)
VITE_AI_PROVIDER=mock

# ATENÇÃO — as chaves abaixo (sem prefixo VITE_) são diferentes de tudo acima:
# elas NUNCA vão pro .env.local nem pro bundle do navegador. Só existem no
# servidor (Netlify Functions). Configure a que for usar em:
# Netlify → Site settings → Environment variables

# Se VITE_AI_PROVIDER=gemini — pegue em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Se VITE_AI_PROVIDER=groq — pegue em https://console.groq.com/keys
# (rápido e com tier gratuito generoso — bom padrão pra começar)
GROQ_API_KEY=
